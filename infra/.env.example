# ------------------------------
# Recommended .NET hierarchical env vars
# ------------------------------
# ASPNETCORE_ENVIRONMENT=Development
# DOTNET_ENVIRONMENT=Development

# ConnectionStrings__Default=Host=localhost;Port=5432;Database=template;Username=template;Password=template-change
# Redis__Configuration=localhost:6379
# RabbitMQ__HostName=localhost
# RabbitMQ__Port=5672
# RabbitMQ__UserName=guest
# RabbitMQ__Password=guest
# RabbitMQ__VirtualHost=/

# Auth__Authority=http://localhost:8081/realms/template
# Auth__RequireHttpsMetadata=false
# Auth__Audience=template-api

