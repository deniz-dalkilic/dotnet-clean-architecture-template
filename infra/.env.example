# ------------------------------
# Core infrastructure
# ------------------------------
APP_POSTGRES_DB=template
APP_POSTGRES_USER=template
APP_POSTGRES_PASSWORD=template-change
APP_POSTGRES_PORT=5432

REDIS_PORT=6379

RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

